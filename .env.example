# ================================================================
# News Facebook Bot - Cấu hình
# Sao chép file này thành .env và điền thông tin thực tế
# ================================================================

# --- Facebook Graph API ---
# Lấy từ: https://developers.facebook.com/tools/explorer/
# Cần quyền: pages_manage_posts, pages_read_engagement
FB_PAGE_ID=YOUR_PAGE_ID_HERE
FB_ACCESS_TOKEN=YOUR_LONG_LIVED_PAGE_ACCESS_TOKEN_HERE
FB_API_VERSION=v19.0

# --- Lịch đăng bài (HH:MM, 24 giờ, phân cách bằng dấu phẩy) ---
SCHEDULE_TIMES=07:00,12:00,18:00

# --- Cấu hình lấy tin ---
MAX_ITEMS_PER_SOURCE=10
TOTAL_CARDS_ON_IMAGE=5
REQUEST_TIMEOUT=10

# --- Tùy chỉnh giao diện ---
BRAND_NAME=Tin Tức Hôm Nay

# --- Thư mục ---
OUTPUT_DIR=output
LOG_DIR=logs
POST_LOG_PATH=output/post_log.json
FONT_DIR=assets/fonts
